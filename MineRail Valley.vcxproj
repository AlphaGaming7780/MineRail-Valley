      <Command>@echo ====== Copying SFML DLLs to output directory ======

:: 📁 Chemin vers le dossier bin de ta SFML (à adapter si besoin)
set "SFML_DIR=$(ProjectDir)SFML\bin"

:: 📁 Dossier de sortie du projet (x64\Debug ou x64\Release)
set "TARGET_DIR=$(TargetDir)"

:: 🔍 Détection automatique du suffixe (-d pour Debug)
if /I "$(Configuration)"=="Debug" (
    set "SUFFIX=-d-3"
) else (
    set "SUFFIX=-3"
)

:: 🧩 Liste des modules SFML que ton projet utilise
set DLLS=sfml-system sfml-window sfml-graphics sfml-audio sfml-network

:: 🚀 Boucle de copie automatique
for %%D in (%DLLS%) do (
    set "FILE=%%D%SUFFIX%.dll"
    setlocal enabledelayedexpansion
    if exist "%SFML_DIR%\!FILE!" (
        echo Copying !FILE! ...
        copy /Y "%SFML_DIR%\!FILE!" "%TARGET_DIR%" &gt;nul
    ) else (
        echo WARNING: !FILE! not found in %SFML_DIR%
    )
    endlocal
)

@echo ====== SFML DLL copy complete ======

@echo ====== Copy ressources folder ========
xcopy /E /I /Y "$(ProjectDir)assets" "$(TargetDir)assets\"
@echo ======== Copy completed ==========
</Command>
